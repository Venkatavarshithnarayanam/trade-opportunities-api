# Trade Opportunities API - Environment Configuration

# Port configuration (default: 8001)
PORT=8001

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Gemini API Key (optional - uses fallback if not set)
GEMINI_API_KEY=your-gemini-api-key-here

# API Key for authentication
API_KEY=trade-api-key-2024
